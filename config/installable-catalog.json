{
  "version": 1,
  "modules": [
    {
      "id": "harness",
      "kind": "core",
      "sourceRoot": ".",
      "optional": false,
      "hosts": ["claude", "codex", "opencode", "pi", "agent"],
      "description": "Spec→build→QA→Goal Review workflow plugin"
    },
    {
      "id": "skill-creator",
      "kind": "optional-bundle",
      "sourceRoot": "packages/skill-creator",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "pi", "agent"],
      "description": "Create and evaluate agent skills"
    },
    {
      "id": "crawl4ai",
      "kind": "optional-bundle",
      "sourceRoot": "packages/crawl4ai",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "pi", "agent"],
      "description": "Crawl4AI web extraction skill",
      "runtime": { "pip": ["crawl4ai"] }
    },
    {
      "id": "ponytail",
      "kind": "external",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Minimal-solution coding skill",
      "acquisition": { "npm": "@dietrichgebert/ponytail", "github": "DietrichGebert/ponytail" }
    },
    {
      "id": "lavish-axi",
      "kind": "external",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Lavish Editor for agent HTML artifacts",
      "acquisition": {
        "skills": { "repo": "kunchenguid/lavish-axi", "name": "lavish", "global": true }
      }
    },
    {
      "id": "hallmark",
      "kind": "external",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Anti-AI-slop design skill",
      "acquisition": {
        "skills": { "repo": "nutlope/hallmark", "name": "hallmark", "global": true }
      }
    },
    {
      "id": "no-mistakes",
      "kind": "external",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "pi", "agent"],
      "description": "Git push gate with AI validation pipeline",
      "acquisition": {
        "installer": "https://raw.githubusercontent.com/kunchenguid/no-mistakes/main/docs/install.sh",
        "installerWindows": "https://raw.githubusercontent.com/kunchenguid/no-mistakes/main/docs/install.ps1"
      }
    },
    {
      "id": "treehouse",
      "kind": "external",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Reusable git worktree pool for agents",
      "acquisition": {
        "installer": "https://kunchenguid.github.io/treehouse/install.sh",
        "installerWindows": "https://kunchenguid.github.io/treehouse/install.ps1"
      }
    },
    {
      "id": "firstmate",
      "kind": "external",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "pi", "agent"],
      "description": "Orchestrator agent with a supervised agent crew",
      "acquisition": {
        "clone": "https://github.com/kunchenguid/firstmate.git",
        "cloneDir": ".local/share/firstmate"
      }
    },
    {
      "id": "codebase-memory-mcp",
      "kind": "external",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Codebase memory MCP server",
      "acquisition": { "installer": "https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/install.sh" }
    },
    {
      "id": "context7",
      "kind": "mcp",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Context7 docs MCP"
    },
    {
      "id": "playwright",
      "kind": "mcp",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Playwright browser MCP"
    },
    {
      "id": "status-line",
      "kind": "extra",
      "optional": true,
      "hosts": ["claude", "codex"],
      "description": "Status line helpers"
    },
    {
      "id": "shared-config",
      "kind": "extra",
      "optional": true,
      "hosts": ["claude"],
      "description": "Shared Claude settings merge"
    },
    {
      "id": "mcp-servers",
      "kind": "extra",
      "optional": true,
      "hosts": ["claude", "codex", "opencode", "agent"],
      "description": "Restore MCP inventory with secret prompts"
    }
  ]
}
